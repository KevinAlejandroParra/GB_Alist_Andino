{"name":"server","version":"1.0.0","main":"index.js","scripts":{"test":"echo \"Error: no test specified\" && exit 1","start":"node --watch src/index.js","swagger":"node src/swagger.js","server":"npm run swagger && node --watch src/index.js","db:migrate":"npx sequelize-cli db:migrate","db:migrate:undo":"npx sequelize-cli db:migrate:undo","db:seed":"npx sequelize-cli db:seed:all","db:seed:undo":"npx sequelize-cli db:seed:undo:all","db:reset":"npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all","db:reset:seeds":"npx sequelize-cli db:seed:undo:all && npx sequelize-cli db:seed:all","seed:all":"node run-seeders.js","seed:simple":"node run-seeders-simple.js","seed:list":"node -e \"console.log('Seeders disponibles: 1,2,3,4,5,6,8,9,10,11,12,13')\""},"keywords":[],"author":"Kevin Alejandro Parra Cifuentes <luisparra5380@gmail.com>","license":"ISC","description":"API para el sistema de gestión de Alist Andino","dependencies":{"bcrypt":"^5.1.1","cors":"^2.8.5","dotenv":"^17.2.1","express":"^4.21.2","jsonwebtoken":"^9.0.2","multer":"^2.0.2","mysql2":"^3.15.2","nodemailer":"^7.0.5","pg":"^8.16.3","puppeteer":"^24.22.0","qrcode":"^1.5.4","sequelize":"^6.37.7","sequelize-cli":"^6.6.3","swagger-autogen":"^2.23.7","swagger-ui-express":"^5.0.1"}}